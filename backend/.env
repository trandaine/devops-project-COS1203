# ======================
# SERVER CONFIG
# ======================
PORT=8080
NODE_ENV=development

# ======================
# DATABASE CONFIG (PostgreSQL)
# ======================
# DB_USER=admin
DB_USER=postgres
DB_PASSWORD=12345678
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres

# ======================
# SECURITY
# ======================
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=1d

# ======================
# CORS
# ======================
CORS_ORIGIN=http://localhost:3000

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug